{%- comment -%}
  ============================================
  CAPALA Size Guide Component
  ============================================

  A responsive size guide with CM/IN toggle
  for Tops, Bottoms, and One Pieces categories.

  INSTALLATION:
  1. In Shopify admin, go to Online Store > Themes
  2. Click Actions > Edit code
  3. Under Sections, click "Add a new section"
  4. Name it "size-guide" and paste this content
  5. Save and add to your desired page

  CUSTOMISATION:
  Edit the CSS variables in :root to change colors,
  fonts, and spacing to match your theme.

  DO NOT edit this file directly.
  Make changes in /src/index.html and rebuild.
{%- endcomment -%}

<style>
  /* CSS Variables for easy customisation */
  :root {
    --sg-font-heading: Georgia, 'Times New Roman', serif;
    --sg-font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --sg-color-bg: #ffffff;
    --sg-color-tab-active: #f5f5f5;
    --sg-color-border: #e5e5e5;
    --sg-color-text: #333333;
    --sg-color-text-light: #666666;
    --sg-color-text-header: #888888;
    --sg-max-width: 1000px;
  }

  .size-guide * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* Size Guide Container */
  .size-guide {
    max-width: var(--sg-max-width);
    margin: 0 auto;
    padding: 40px 20px;
    font-family: var(--sg-font-body);
    color: var(--sg-color-text);
    background: var(--sg-color-bg);
    line-height: 1.5;
  }

  .size-guide__title {
    font-family: var(--sg-font-heading);
    font-size: 28px;
    font-weight: 400;
    text-align: center;
    letter-spacing: 0.15em;
    margin-bottom: 40px;
  }

  .size-guide__header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 20px;
  }

  .size-guide__container {
    display: flex;
    gap: 0;
    align-items: flex-start;
  }

  /* Tabs Sidebar */
  .size-guide__tabs {
    display: flex;
    flex-direction: column;
    min-width: 180px;
    border-right: 1px solid var(--sg-color-border);
    flex-shrink: 0;
  }

  .size-guide__tab {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px 24px;
    background: transparent;
    border: none;
    cursor: pointer;
    font-family: var(--sg-font-body);
    font-size: 15px;
    color: var(--sg-color-text);
    text-align: left;
    transition: background-color 0.2s ease;
  }

  .size-guide__tab:hover {
    background-color: var(--sg-color-tab-active);
  }

  .size-guide__tab.active {
    background-color: var(--sg-color-tab-active);
  }

  .size-guide__tab svg {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  /* Content Area */
  .size-guide__content {
    flex: 1;
    padding: 0 0 0 30px;
    overflow-x: auto;
    min-width: 0;
  }

  /* Toggle Switch */
  .size-guide__toggle-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .size-guide__toggle-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--sg-color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .size-guide__toggle-label.active {
    color: var(--sg-color-text);
  }

  .size-guide__toggle {
    position: relative;
    width: 44px;
    height: 24px;
  }

  .size-guide__toggle input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .size-guide__toggle-slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--sg-color-text);
    border-radius: 24px;
    transition: 0.3s;
  }

  .size-guide__toggle-slider:before {
    position: absolute;
    content: "";
    height: 18px;
    width: 18px;
    left: 3px;
    bottom: 3px;
    background-color: white;
    border-radius: 50%;
    transition: 0.3s;
  }

  .size-guide__toggle input:checked + .size-guide__toggle-slider:before {
    transform: translateX(20px);
  }

  /* Table Styles */
  .size-guide__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .size-guide__table th {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--sg-color-text-header);
    text-align: center;
    padding: 12px 10px;
    border-bottom: 1px solid var(--sg-color-border);
    white-space: nowrap;
  }

  .size-guide__table td {
    padding: 14px 10px;
    border-bottom: 1px solid var(--sg-color-border);
    color: var(--sg-color-text);
    white-space: nowrap;
    text-align: center;
  }

  .size-guide__table tr:last-child td {
    border-bottom: none;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .size-guide {
      padding: 30px 15px;
    }

    .size-guide__title {
      font-size: 24px;
      margin-bottom: 20px;
    }

    .size-guide__header {
      margin-bottom: 15px;
    }

    .size-guide__container {
      flex-direction: column;
    }

    .size-guide__tabs {
      flex-direction: row;
      min-width: auto;
      border-right: none;
      border-bottom: 1px solid var(--sg-color-border);
      overflow-x: auto;
    }

    .size-guide__tab {
      flex: 1;
      flex-direction: column;
      padding: 15px 12px;
      text-align: center;
      gap: 8px;
      font-size: 13px;
      white-space: nowrap;
    }

    .size-guide__tab svg {
      width: 24px;
      height: 24px;
    }

    .size-guide__content {
      padding: 20px 0 0 0;
    }

    .size-guide__table {
      font-size: 12px;
    }

    .size-guide__table th,
    .size-guide__table td {
      padding: 10px 6px;
    }

    .size-guide__table th {
      font-size: 9px;
    }
  }
</style>

<div class="size-guide">
  <h2 class="size-guide__title">SIZE CHART</h2>

  <!-- Toggle above everything -->
  <div class="size-guide__header">
    <div class="size-guide__toggle-wrapper">
      <span class="size-guide__toggle-label" id="label-cm">CM</span>
      <label class="size-guide__toggle">
        <input type="checkbox" id="unit-toggle" checked>
        <span class="size-guide__toggle-slider"></span>
      </label>
      <span class="size-guide__toggle-label active" id="label-in">IN</span>
    </div>
  </div>

  <div class="size-guide__container">
    <!-- Tabs Sidebar -->
    <div class="size-guide__tabs">
      <button class="size-guide__tab active" data-category="tops">
        <!-- Bikini Top Icon -->
        <svg viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M7 6.5C7 6 7.5 5.5 8 5.5s1 .5 1 1v4c0 .5-.5 1-1 1s-1-.5-1-1v-4z"/>
          <path d="M23 6.5c0-.5.5-1 1-1s1 .5 1 1v4c0 .5-.5 1-1 1s-1-.5-1-1v-4z"/>
          <path d="M4 15c0-4 3-7 7-7 2 0 4 1 5 3v2c-1 2-3 3-5 3-4 0-7-1-7-1z"/>
          <path d="M28 15c0-4-3-7-7-7-2 0-4 1-5 3v2c1 2 3 3 5 3 4 0 7-1 7-1z"/>
          <path d="M14 11c0-.5.5-1 1-1h2c.5 0 1 .5 1 1v2c0 .5-.5 1-1 1h-2c-.5 0-1-.5-1-1v-2z"/>
        </svg>
        Tops
      </button>
      <button class="size-guide__tab" data-category="bottoms">
        <!-- Bikini Bottom Icon -->
        <svg viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 10c0-.5.4-1 1-1h20c.6 0 1 .5 1 1 0 0-2 4-5 7-2 2-4 6-5 9-.3.5-.7 1-1 1s-.7-.5-1-1c-1-3-3-7-5-9-3-3-5-7-5-7z"/>
        </svg>
        Bottoms
      </button>
      <button class="size-guide__tab" data-category="onepieces">
        <!-- One Piece Swimsuit Icon -->
        <svg viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M10 4c-.5 0-1 .5-1 1v5h2V5c0-.5-.5-1-1-1z"/>
          <path d="M22 4c-.5 0-1 .5-1 1v5h2V5c0-.5-.5-1-1-1z"/>
          <path d="M9 9c-1 0-2 1-2 2v4c0 2 1 4 2 6l1 6c0 1 1 2 2 2h8c1 0 2-1 2-2l1-6c1-2 2-4 2-6v-4c0-1-1-2-2-2H9z"/>
          <path d="M12 9c0 2 2 4 4 4s4-2 4-4h-8z" fill="white"/>
        </svg>
        One Pieces
      </button>
    </div>

    <!-- Content Area -->
    <div class="size-guide__content">
      <table class="size-guide__table" id="size-table">
        <!-- Table content will be rendered by JavaScript -->
      </table>
    </div>
  </div>
</div>

<script>
  (function() {
    var sizeData = {
      tops: {
        headers: ['CAPALA SIZE', 'UK DRESS SIZE', 'BUST', 'UNDERBUST', 'US DRESS SIZE', 'EU DRESS SIZE'],
        convertibleColumns: [2, 3],
        rows: [
          ['XS', '6', [30, 31], [25, 26], '2', '36'],
          ['S', '8', [32, 33], [27, 28], '4', '38'],
          ['M', '10', [34, 35], [29, 30], '6', '40'],
          ['L', '12', [36, 38], [31, 32], '8', '42'],
          ['XL', '14', [39, 41], [33, 34], '10', '44']
        ]
      },
      bottoms: {
        headers: ['CAPALA SIZE', 'UK DRESS SIZE', 'WAIST', 'HIPS', 'US DRESS SIZE', 'EU DRESS SIZE'],
        convertibleColumns: [2, 3],
        rows: [
          ['XS', '6', [23, 24], [34, 35], '2', '36'],
          ['S', '8', [25, 26], [36, 37], '4', '38'],
          ['M', '10', [27, 28], [38, 39], '6', '40'],
          ['L', '12', [29, 30], [40, 41], '8', '42'],
          ['XL', '14', [31, 32], [42, 43], '10', '44']
        ]
      },
      onepieces: {
        headers: ['CAPALA SIZE', 'UK DRESS SIZE', 'BUST', 'UNDERBUST', 'WAIST', 'HIPS', 'US DRESS SIZE', 'EU DRESS SIZE'],
        convertibleColumns: [2, 3, 4, 5],
        rows: [
          ['XS', '6', [30, 31], [25, 26], [23, 24], [34, 35], '2', '36'],
          ['S', '8', [32, 33], [27, 28], [25, 26], [36, 37], '4', '38'],
          ['M', '10', [34, 35], [29, 30], [27, 28], [38, 39], '6', '40'],
          ['L', '12', [36, 38], [31, 32], [29, 30], [40, 41], '8', '42'],
          ['XL', '14', [39, 41], [33, 34], [31, 32], [42, 43], '10', '44']
        ]
      }
    };

    var currentCategory = 'tops';
    var useInches = true;

    function inchesToCm(inches) {
      var cm = inches * 2.54;
      return Math.round(cm * 2) / 2;
    }

    function formatMeasurement(value, convertToCm) {
      if (Array.isArray(value)) {
        if (convertToCm) {
          return inchesToCm(value[0]) + '-' + inchesToCm(value[1]);
        }
        return value[0] + '-' + value[1];
      }
      return value;
    }

    function renderTable() {
      var data = sizeData[currentCategory];
      var table = document.getElementById('size-table');

      var html = '<thead><tr>';
      data.headers.forEach(function(header) {
        html += '<th>' + header + '</th>';
      });
      html += '</tr></thead>';

      html += '<tbody>';
      data.rows.forEach(function(row) {
        html += '<tr>';
        row.forEach(function(cell, index) {
          var shouldConvert = data.convertibleColumns.indexOf(index) !== -1 && !useInches;
          html += '<td>' + formatMeasurement(cell, shouldConvert) + '</td>';
        });
        html += '</tr>';
      });
      html += '</tbody>';

      table.innerHTML = html;
    }

    function updateToggleLabels() {
      document.getElementById('label-cm').classList.toggle('active', !useInches);
      document.getElementById('label-in').classList.toggle('active', useInches);
    }

    function handleTabClick(e) {
      var tab = e.currentTarget;
      var category = tab.dataset.category;

      document.querySelectorAll('.size-guide__tab').forEach(function(t) {
        t.classList.remove('active');
      });
      tab.classList.add('active');

      currentCategory = category;
      renderTable();
    }

    function handleToggle(e) {
      useInches = e.target.checked;
      updateToggleLabels();
      renderTable();
    }

    document.querySelectorAll('.size-guide__tab').forEach(function(tab) {
      tab.addEventListener('click', handleTabClick);
    });

    document.getElementById('unit-toggle').addEventListener('change', handleToggle);

    renderTable();
    updateToggleLabels();
  })();
</script>

{% schema %}
{
  "name": "Size Guide",
  "settings": [],
  "presets": [
    {
      "name": "Size Guide"
    }
  ]
}
{% endschema %}
